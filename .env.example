# Strix Telegram Bot — Configuration
# Copy this file to .env_bot and fill in your values.

# Telegram Bot Token (required)
# Get it from @BotFather on Telegram
STRIX_TG_TOKEN="your_bot_token_here"

# Telegram User IDs allowed to use the bot (required)
# Comma-separated list of numeric user IDs
STRIX_TG_ALLOWED_USERS="123456789,987654321"

# Telegram Chat IDs allowed (optional)
# Leave empty to allow any chat with an allowed user
STRIX_TG_ALLOWED_CHATS=""

# LLM model for Strix scans (required)
STRIX_LLM="deepseek/deepseek-v4-pro"

# LLM API Key (required)
LLM_API_KEY="sk-your_api_key_here"

# Job timeout in seconds (optional, default: 7200 = 2 hours)
STRIX_JOB_TIMEOUT_SECONDS="7200"

# Working directory for scan results (optional)
STRIX_WORK_ROOT="./strix_runs"
