# STRIX Telegram Bot — Environment Variables
# Copy this to .env_bot and fill in your values.

# Telegram bot token from @BotFather
STRIX_TG_TOKEN="your_telegram_bot_token_here"

# Comma-separated Telegram user IDs with access
STRIX_TG_ALLOWED_USERS="your_user_id_here"

# Comma-separated chat IDs with access
STRIX_TG_ALLOWED_CHATS="your_chat_id_here"

# LLM model for STRIX
STRIX_LLM="deepseek/deepseek-v4-pro"

# LLM API key
LLM_API_KEY="your_llm_api_key_here"

# Path to strix binary (optional, defaults to searching PATH)
# STRIX_BIN="/home/user/.local/bin/strix"

# Bot working directory (optional, defaults to current directory)
# STRIX_BOT_DIR="/home/user/strix-telegram-bot"

# Directory for strix run outputs (optional, defaults to $STRIX_BOT_DIR/strix_runs)
# STRIX_RUNS_DIR="/home/user/strix_runs"
